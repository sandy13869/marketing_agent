# ─────────────────────────────────────────────
# Instagram / Meta
# ─────────────────────────────────────────────
# Your Meta App ID (from developers.facebook.com)
META_APP_ID=

# Your Meta App Secret (from App Dashboard > Settings > Basic)
META_APP_SECRET=

# Instagram User ID of your Business/Creator account
# Obtain via: GET https://graph.instagram.com/me?fields=id&access_token=<TOKEN>
IG_USER_ID=

# Long-lived Instagram access token (valid 60 days, auto-refreshed by tokenRefresh.js)
IG_ACCESS_TOKEN=

# Unix timestamp (seconds) when the above token expires
# Used by tokenRefresh.js to decide when to refresh
IG_ACCESS_TOKEN_EXPIRY=

# ─────────────────────────────────────────────
# Google Gemini
# ─────────────────────────────────────────────
# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Reddit API  (https://www.reddit.com/prefs/apps → create "script" app)
# ─────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ─────────────────────────────────────────────
# MinIO (self-hosted S3-compatible object storage)
# ─────────────────────────────────────────────
# Internal hostname (Docker service name or IP for local use)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=instagram-agent

# Public base URL that Instagram (Meta's CDN crawler) can reach to fetch images.
# For local Docker: expose MinIO on a public IP/domain or use ngrok.
# Example: http://YOUR_PUBLIC_IP:9000  or  https://your-domain.com
MINIO_PUBLIC_BASE_URL=http://localhost:9000

# ─────────────────────────────────────────────
# Redis (BullMQ job queue)
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─────────────────────────────────────────────
# Posting schedule (node-cron format, UTC)
# Default: 9am and 6pm UTC daily
# ─────────────────────────────────────────────
POST_CRON_SCHEDULE=0 9,18 * * *
POST_TIMEZONE=UTC

# ─────────────────────────────────────────────
# App behaviour
# ─────────────────────────────────────────────
# Set to "true" to run the full pipeline without actually posting to Instagram
DRY_RUN=false

# Target geo for Google Trends (ISO 3166-1 alpha-2)
TRENDS_GEO=US

# Comma-separated subreddits to monitor for tech trends
REDDIT_SUBREDDITS=technology,gadgets,MachineLearning,programming,artificial

# Number of top Reddit posts to analyse per subreddit (max 25)
REDDIT_POST_LIMIT=10

# Max carousel slides (2-10; Instagram limit is 10)
CAROUSEL_SLIDE_COUNT=5

# Log level: error | warn | info | debug
LOG_LEVEL=info
